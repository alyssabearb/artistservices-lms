# Required: Airtable (server-side only — never expose PAT to the browser)
AIRTABLE_PAT=
AIRTABLE_BASE_ID=

# Optional: override Airtable table names if yours differ (must match Softr block data sources)
# Default is Contacts; Softr LMS docs often use "All Personnel" instead:
# AIRTABLE_TABLE_CONTACTS=All Personnel
# AIRTABLE_TABLE_CONTACTS=Contacts
# AIRTABLE_TABLE_ASSIGNMENTS=Assignments
# AIRTABLE_TABLE_TRACKS=Learning Tracks
# AIRTABLE_TABLE_COURSES=Courses
# AIRTABLE_TABLE_SECTIONS=Training Sections
# AIRTABLE_TABLE_RESOURCES=Resource Library

# Optional: primary email field on Contacts for formula lookup (default: Email)
# AIRTABLE_CONTACT_EMAIL_FIELD=Email

# Public: progress proxy (defaults to Netlify proxy if unset)
# NEXT_PUBLIC_PROGRESS_API_URL=https://softr-learning-tracks-webhook-proxy.netlify.app/api/progress

# Public: section view + completion webhooks (defaults match Softr blocks)
# NEXT_PUBLIC_SECTION_VIEW_URL=https://softr-learning-tracks-webhook-proxy.netlify.app/api/section-view
# NEXT_PUBLIC_COMPLETE_API_URL=https://softr-learning-tracks-webhook-proxy.netlify.app/api/complete

# Public: learning track opened after Finish / Back to track from the course reader (default recpWuXPzsryX0TTP if unset)
# NEXT_PUBLIC_FINISH_FALLBACK_TRACK_RECORD_ID=recXXXXXXXXXXXXXX
